  _tmux kill-pane -t "${new_pane_id}" 2>/dev/null || true
  sleep 0.05

  cs_scan_sessions

  local np
  np=$(cs_read_state new_pane)
  [[ -z "${np}" ]] || { echo "    new_pane not cleared after cancel"; return 1; }
  cs_assert_consistent "new_cancelled"
