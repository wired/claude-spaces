  [[ ${#ENTRIES_ID[@]} -eq 1 ]] || { echo "    expected 1 entry after hide, got ${#ENTRIES_ID[@]}"; return 1; }
  local idx
  idx=$(find_entry_index "${sid_a}")
  [[ "${idx}" == "-1" ]] || { echo "    hidden session still in list"; return 1; }
  cs_assert_consistent "hide_session"
}

test_hide_older() {
  local sid_a="aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa"
