test_bell_detection() {
  local sid="aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa"
  cs_create_mock_session "${sid}" "bell test"

  # Resume and park it (create a second to make it background)
  cs_resume_session "${sid}"
  sleep 0.05
  local pane_a
  pane_a=$(cs_read_state current_pane)

  local sid_b="bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbbb"
  cs_create_mock_session "${sid_b}" "foreground"
  cs_resume_session "${sid_b}"
  sleep 0.05

  # Write bell for pane A
  echo "${pane_a}" > "${STATE_DIR}/bells"
  cs_check_bells

  [[ -n "${BELL_SET[${pane_a}]:-}" ]] || { echo "    BELL_SET not set for pane A"; return 1; }

  # Show pane A — bell should clear
  cs_show_pane "${pane_a}"
  sleep 0.05
  [[ -z "${BELL_SET[${pane_a}]:-}" ]] || { echo "    BELL_SET not cleared after showing"; return 1; }
  cs_assert_consistent "bell_detection"
}

test_remote_bell() {
  local sid="cccccccc-cccc-cccc-cccc-cccccccccccc"
  local remote_state="${STATE_DIR}/mock_remote"
  local remote_project="${MOCK_PROJECT_DIR}_remote"
  mkdir -p "${remote_state}/panes" "${remote_project}"

  # Create a session JSONL in the remote project dir
  printf '{"type":"user","message":{"role":"user","content":"remote"},"sessionId":"%s"}\n' \
    "${sid}" > "${remote_project}/${sid}.jsonl"

  # Mark it as managed (has a pane file)
  echo "${sid}" > "${remote_state}/panes/99"

  # Write bells_active with the session UUID
  echo "${sid}" > "${remote_state}/bells_active"

  # Scan remote sessions
  cs_entry_clear
  cs_scan_project_sessions "${remote_project}" "/tmp/fake" "remote" "${remote_state}"

  # Find the entry and check its status
  local found=0
  for ((i=0; i < ${#ENTRIES_ID[@]}; i++)); do
    if [[ "${ENTRIES_ID[${i}]}" == "${sid}" ]]; then
      [[ "${ENTRIES_STATUS[${i}]}" == "bell" ]] || { echo "    expected status 'bell', got '${ENTRIES_STATUS[${i}]}'"; return 1; }
      found=1
      break
    fi
  done
  ((found)) || { echo "    remote session not found in entries"; return 1; }

  # Clear bells_active — status should revert to managed
  : > "${remote_state}/bells_active"
  cs_entry_clear
  cs_scan_project_sessions "${remote_project}" "/tmp/fake" "remote" "${remote_state}"

  for ((i=0; i < ${#ENTRIES_ID[@]}; i++)); do
    if [[ "${ENTRIES_ID[${i}]}" == "${sid}" ]]; then
      [[ "${ENTRIES_STATUS[${i}]}" == "managed" ]] || { echo "    expected status 'managed' after clear, got '${ENTRIES_STATUS[${i}]}'"; return 1; }
      break
    fi
  done

  rm -rf "${remote_state}" "${remote_project}"
}

test_hide_session() {
  local sid_a="aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa"
  local sid_b="bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbbb"
  cs_create_mock_session "${sid_a}" "to hide"
  cs_create_mock_session "${sid_b}" "to keep"
  cs_scan_sessions
