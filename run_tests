  (( sess_h >= MIN_CLAUDE_HEIGHT )) || { echo "    claude pane too short: ${sess_h} < ${MIN_CLAUDE_HEIGHT}"; TERMINAL_HEIGHT="${old_th}"; MIN_CLAUDE_HEIGHT="${old_mch}"; return 1; }

  cs_term_kill "${pane_a}"
  TERMINAL_HEIGHT="${old_th}"
  MIN_CLAUDE_HEIGHT="${old_mch}"
  cs_assert_consistent "min_claude_height"
}

test_session_dies_externally_with_term() {
  local sid="aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa"
  cs_create_mock_session "${sid}" "session A"
  cs_scan_sessions
