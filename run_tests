test_new_then_select_other() {
  local sid="aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa"
  cs_create_mock_session "${sid}" "existing"

  cs_new_session
  sleep 0.05
  local new_pane_id
  new_pane_id=$(cs_read_state new_pane)

  cs_scan_sessions
  local idx
  idx=$(find_entry_index "${sid}")
  [[ "${idx}" != "-1" ]] || { echo "    existing session not found"; return 1; }
