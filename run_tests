# Re-exec under bash 4.3+ on macOS if needed
if ((BASH_VERSINFO[0] < 4 || (BASH_VERSINFO[0] == 4 && BASH_VERSINFO[1] < 3))); then
  for _bash in /opt/homebrew/bin/bash /usr/local/bin/bash; do
    [[ -x "$_bash" ]] && exec "$_bash" "$0" "$@"
  done
  echo "ERROR: bash 4.3+ required (found ${BASH_VERSION}). On macOS: brew install bash and add Homebrew's bin to your PATH before /bin"
  exit 1
fi

SCRIPT_UNDER_TEST="${SCRIPT_UNDER_TEST:-$(dirname "$(readlink -f "$0")")/claude-spaces}"

RED='\033[31m'
GREEN='\033[32m'
BOLD='\033[1m'
RESET='\033[0m'

PASS_COUNT=0
FAIL_COUNT=0

# ── Phase 1: shellcheck ──────────────────────────
phase_shellcheck() {
  echo "Running shellcheck..."
  if ! shellcheck -S warning "${SCRIPT_UNDER_TEST}"; then
    echo -e "${RED}shellcheck failed${RESET}"
    exit 1
  fi
  echo -e "${GREEN}shellcheck passed${RESET}"
  echo ""
}

phase_arg_checks() {
  echo "Running arg checks..."
  local errors=0
  for func_sig in "cs_entry_append:7" "cs_entry_prepend:7"; do
    local func="${func_sig%%:*}"
    local expected="${func_sig##*:}"
    while IFS=: read -r linenum content; do
      local count
      count=$(echo "${content}" | grep -o '"' | wc -l)
      count=$((count / 2))
      if ((count != expected)); then
        echo -e "  ${RED}Line ${linenum}: ${func} has ${count} args (expected ${expected})${RESET}"
        ((errors++))
      fi
    done < <(grep -n "${func} " "${SCRIPT_UNDER_TEST}" | grep -v '^\s*#' | grep -v "${func}()" | grep -v "${func}() {" | grep -v "echo.*${func}")
  done
  if ((errors > 0)); then
    echo -e "${RED}arg checks failed${RESET}"
    exit 1
  fi
  echo -e "${GREEN}arg checks passed${RESET}"
  echo ""
}

# ── Source functions ──────────────────────────────
load_functions() {
  eval "$(sed -n '1,/^# ── Entrypoint/p' "${SCRIPT_UNDER_TEST}" | sed '$d')"
}

# ── Mock overrides ───────────────────────────────
mock_cs_new_session() {
  local auto_name="${2:-}"
  local old_new
  old_new=$(cs_read_state new_pane)
  if [[ -n "${old_new}" ]]; then
    _tmux kill-pane -t "${old_new}" 2>/dev/null || true
    rm -f "${STATE_DIR}/panes/${old_new#%}" "${STATE_DIR}/new_pane" "${STATE_DIR}/new_pane_auto_name"
  fi
  local pane_id
  pane_id=$(_tmux new-window -d -t "${TEST_SESSION}" -P -F '#{pane_id}' "sleep 99999")
  echo "new" > "${STATE_DIR}/panes/${pane_id#%}"
  echo "${pane_id}" > "${STATE_DIR}/new_pane"
  if [[ -n "${auto_name}" ]]; then
    echo "${auto_name}" > "${STATE_DIR}/new_pane_auto_name"
  else
    rm -f "${STATE_DIR}/new_pane_auto_name"
  fi
  cs_show_pane "${pane_id}"
}

mock_cs_resume_session() {
  local session_id="$1"
  local pane_id
  pane_id=$(_tmux new-window -d -t "${TEST_SESSION}" -P -F '#{pane_id}' "sleep 99999")
  echo "${session_id}" > "${STATE_DIR}/panes/${pane_id#%}"
  cs_show_pane "${pane_id}"
}

mock_cs_show_welcome() {
  local welcome_pane
  welcome_pane=$(_tmux new-window -d -t "${TEST_SESSION}" -P -F '#{pane_id}' "sleep 99999")
  echo "${welcome_pane}" > "${STATE_DIR}/welcome_pane"
  cs_show_pane "${welcome_pane}"
}

install_mocks() {
  eval 'cs_new_session() { mock_cs_new_session "$@"; }'
  eval 'cs_resume_session() { mock_cs_resume_session "$@"; }'
  eval 'cs_show_welcome() { mock_cs_show_welcome "$@"; }'
}

# ── Test helpers ─────────────────────────────────
pane_alive() {
  cs_refresh_pane_cache
  cs_pane_alive "$1"
}

cs_create_mock_session() {
  local sid="$1" message="${2:-Test session}"
  printf '{"type":"user","message":{"role":"user","content":"%s"},"sessionId":"%s"}\n' \
    "${message}" "${sid}" > "${MOCK_PROJECT_DIR}/${sid}.jsonl"
}

find_entry_index() {
  local target_id="$1"
  for ((i=0; i < ${#ENTRIES_ID[@]}; i++)); do
    if [[ "${ENTRIES_ID[${i}]}" == "${target_id}" ]]; then
      echo "${i}"
      return
    fi
  done
  echo "-1"
}

# ── State invariant checker ──────────────────────
cs_assert_consistent() {
  local label="$1"
  local errors=0

  # 1. current_pane: empty or alive
  local cp
  cp=$(cs_read_state current_pane)
  if [[ -n "${cp}" ]] && ! pane_alive "${cp}"; then
    echo -e "    ${RED}FAIL${RESET} [${label}] current_pane '${cp}' is dead"
    ((errors++))
  fi

  # 2. new_pane: empty or alive
  local np
  np=$(cs_read_state new_pane)
  if [[ -n "${np}" ]] && ! pane_alive "${np}"; then
    echo -e "    ${RED}FAIL${RESET} [${label}] new_pane '${np}' is dead"
    ((errors++))
  fi

  # 3. welcome_pane: empty or alive
  local wp
  wp=$(cs_read_state welcome_pane)
  if [[ -n "${wp}" ]] && ! pane_alive "${wp}"; then
    echo -e "    ${RED}FAIL${RESET} [${label}] welcome_pane '${wp}' is dead"
    ((errors++))
  fi

  # 4. Every panes/* references a live pane
  for f in "${STATE_DIR}"/panes/*; do
    [[ -f "${f}" ]] || continue
    local pid="%$(basename "${f}")"
    if ! pane_alive "${pid}"; then
      echo -e "    ${RED}FAIL${RESET} [${label}] panes/$(basename "${f}") references dead pane '${pid}'"
      ((errors++))
    fi
  done

  # 5. picker_pane is set and alive
  local pp
  pp=$(cs_read_state picker_pane)
  if [[ -z "${pp}" ]]; then
    echo -e "    ${RED}FAIL${RESET} [${label}] picker_pane is empty"
    ((errors++))
  elif ! pane_alive "${pp}"; then
    echo -e "    ${RED}FAIL${RESET} [${label}] picker_pane '${pp}' is dead"
    ((errors++))
  fi

  # 6. Picker window pane count: 1 (picker only), 2 (picker + session),
  #    or 3 (picker + session + terminal)
  if [[ -n "${pp}" ]] && pane_alive "${pp}"; then
    local picker_window
    picker_window=$(_tmux display-message -t "${pp}" -p '#{window_id}' 2>/dev/null)
    if [[ -n "${picker_window}" ]]; then
      local pane_count expected_panes=1
      pane_count=$(_tmux list-panes -t "${picker_window}" -F '#{pane_id}' 2>/dev/null | wc -l)
      if [[ -n "${cp}" ]] && pane_alive "${cp}"; then
        ((expected_panes++))
        # Check for visible terminal in picker window
        local _tp
        _tp=$(cs_term_pane_for "${cp}")
        if [[ -n "${_tp}" ]] && pane_alive "${_tp}"; then
          local _tp_win
          _tp_win=$(_tmux display-message -t "${_tp}" -p '#{window_id}' 2>/dev/null)
          [[ "${_tp_win}" == "${picker_window}" ]] && ((expected_panes++))
        fi
      fi
      if ((pane_count != expected_panes)); then
        echo -e "    ${RED}FAIL${RESET} [${label}] picker window has ${pane_count} panes (expected ${expected_panes})"
        ((errors++))
      fi
    fi
  fi

  # 7. No untracked windows
  if [[ -n "${pp}" ]] && pane_alive "${pp}"; then
    local -A tracked_windows
    local picker_window
    picker_window=$(_tmux display-message -t "${pp}" -p '#{window_id}' 2>/dev/null)
    tracked_windows["${picker_window}"]=1

    for f in "${STATE_DIR}"/panes/*; do
      [[ -f "${f}" ]] || continue
      local pid="%$(basename "${f}")"
      local wid
      wid=$(_tmux display-message -t "${pid}" -p '#{window_id}' 2>/dev/null) || continue
      tracked_windows["${wid}"]=1
    done

    # Track terminal pane windows
    for f in "${STATE_DIR}"/term/*; do
      [[ -f "${f}" ]] || continue
      [[ "$(basename "${f}")" == *.* ]] && continue
      local tpid
      tpid=$(cat "${f}" 2>/dev/null || true)
      if [[ -n "${tpid}" ]] && pane_alive "${tpid}"; then
        local twid
        twid=$(_tmux display-message -t "${tpid}" -p '#{window_id}' 2>/dev/null) || continue
        tracked_windows["${twid}"]=1
      fi
    done

    if [[ -n "${wp}" ]] && pane_alive "${wp}"; then
      local wwid
      wwid=$(_tmux display-message -t "${wp}" -p '#{window_id}' 2>/dev/null) || true
      [[ -n "${wwid}" ]] && tracked_windows["${wwid}"]=1
    fi

    local all_windows
    all_windows=$(_tmux list-windows -t "${TEST_SESSION}" -F '#{window_id}' 2>/dev/null)
    while IFS= read -r wid; do
      [[ -n "${wid}" ]] || continue
      if [[ -z "${tracked_windows[${wid}]:-}" ]]; then
        echo -e "    ${RED}FAIL${RESET} [${label}] untracked window '${wid}'"
        ((errors++))
      fi
    done <<< "${all_windows}"
  fi

  # 8. Terminal state consistency
  for f in "${STATE_DIR}"/term/*; do
    [[ -f "${f}" ]] || continue
    [[ "$(basename "${f}")" == *.* ]] && continue
    local tpid
    tpid=$(cat "${f}" 2>/dev/null || true)
    if [[ -n "${tpid}" ]] && ! pane_alive "${tpid}"; then
      echo -e "    ${RED}FAIL${RESET} [${label}] term/$(basename "${f}") references dead pane '${tpid}'"
      ((errors++))
    fi
  done
  for f in "${STATE_DIR}"/term/*.shown; do
    [[ -f "${f}" ]] || continue
    local base
    base=$(basename "${f}" .shown)
    if [[ ! -f "${STATE_DIR}/term/${base}" ]]; then
      echo -e "    ${RED}FAIL${RESET} [${label}] term/${base}.shown exists but term/${base} does not"
      ((errors++))
    fi
  done

  return "${errors}"
}

# ── Setup / teardown ─────────────────────────────
cs_test_setup() {
  TEST_TMP=$(mktemp -d)
  TEST_SESSION="cs-test-$$"
  TMUX_SERVER="cs-test-$$"

  mkdir -p "${TEST_TMP}/state/panes" "${TEST_TMP}/state/term"
  mkdir -p "${TEST_TMP}/claude/projects"
  mkdir -p "${TEST_TMP}/claude/sessions"
  mkdir -p "${TEST_TMP}/config"
  mkdir -p "${TEST_TMP}/data"

  CLAUDE_DIR="${TEST_TMP}/claude"
  PROJECTS_DIR="${CLAUDE_DIR}/projects"
  SESSIONS_DIR="${CLAUDE_DIR}/sessions"
  CS_CONFIG_DIR="${TEST_TMP}/config"
  CS_DATA_DIR="${TEST_TMP}/data"
  CONFIG_FILE="${CS_CONFIG_DIR}/config"
  NAMES_FILE="${CS_DATA_DIR}/names"
  HIDDEN_FILE="${CS_DATA_DIR}/hidden"
  PROJECT_NAMES_FILE="${CS_DATA_DIR}/project_names"
  STATE_DIR="${TEST_TMP}/state"

  : > "${CONFIG_FILE}"
  : > "${HIDDEN_FILE}"
  : > "${NAMES_FILE}"
  : > "${PROJECT_NAMES_FILE}"

  MOCK_PWD="/tmp/cs-test-project-$$"
  mkdir -p "${MOCK_PWD}"
  MOCK_PROJECT_DIR="${PROJECTS_DIR}/$(echo "${MOCK_PWD}" | tr '/' '-')"
  mkdir -p "${MOCK_PROJECT_DIR}"

  # Create tmux session
  _tmux new-session -d -s "${TEST_SESSION}" -x 120 -y 40 "sleep 99999"
  sleep 0.05
  PICKER_PANE=$(_tmux list-panes -t "${TEST_SESSION}" -F '#{pane_id}' | head -1)
  echo "${PICKER_PANE}" > "${STATE_DIR}/picker_pane"
  echo $$ > "${STATE_DIR}/picker_pid"
  echo "${MOCK_PWD}" > "${STATE_DIR}/project_path"

  # Override PWD for cs_get_project_dir
  PWD="${MOCK_PWD}"

  # Reduce dormant-activate sleep for tests
  CS_ACTIVATE_DELAY=0.05

  # Initialize globals
  SELECTED=0
  SCROLL=0
  DIRTY=0
  LAST_FINGERPRINT=""
  declare -gA BELL_SET
  NOW=$(date +%s)
}

cs_test_teardown() {
  _tmux kill-session -t "${TEST_SESSION}" 2>/dev/null || true
  rm -rf "${TEST_TMP}"
  rm -rf "${MOCK_PWD}"
}

cs_test_reset() {
  # Kill all panes except picker
  local panes
  panes=$(_tmux list-panes -s -t "${TEST_SESSION}" -F '#{pane_id}' 2>/dev/null)
  while IFS= read -r p; do
    [[ -n "${p}" ]] || continue
    [[ "${p}" == "${PICKER_PANE}" ]] && continue
    _tmux kill-pane -t "${p}" 2>/dev/null || true
  done <<< "${panes}"
  sleep 0.05

  # Clear state
  rm -f "${STATE_DIR}/current_pane" "${STATE_DIR}/new_pane" "${STATE_DIR}/welcome_pane"
  rm -f "${STATE_DIR}/panes/"*
  rm -f "${STATE_DIR}/term/"*
  : > "${STATE_DIR}/bells"
  rm -f "${STATE_DIR}/bells_active" "${STATE_DIR}/bells_active.tmp"
  echo "${PICKER_PANE}" > "${STATE_DIR}/picker_pane"
  echo $$ > "${STATE_DIR}/picker_pid"

  # Reset globals
  ENTRIES_ID=()
  ENTRIES_NAME=()
  ENTRIES_MTIME=()
  ENTRIES_STATUS=()
  ENTRIES_PANE=()
  SELECTED=0
  SCROLL=0
  declare -gA BELL_SET=()

  # Clear mock data
  rm -rf "${MOCK_PROJECT_DIR}"
  mkdir -p "${MOCK_PROJECT_DIR}"
  rm -f "${SESSIONS_DIR}"/*.json
  : > "${HIDDEN_FILE}"
  : > "${NAMES_FILE}"
  : > "${PROJECT_NAMES_FILE}"
  PROJECT_NAMES=()

  sleep 0.05
}

# ── Test runner ──────────────────────────────────
run_test() {
  local name="$1"
  shift
  cs_test_reset
  echo -n "  ${name} ... "
  local output
  if output=$("$@" 2>&1); then
    echo -e "${GREEN}PASS${RESET}"
    ((PASS_COUNT++))
  else
    echo -e "${RED}FAIL${RESET}"
    [[ -n "${output}" ]] && echo "${output}"
    ((FAIL_COUNT++))
  fi
}

# ── Test cases ───────────────────────────────────

test_fresh_start_no_sessions() {
  cs_scan_sessions
  [[ ${#ENTRIES_ID[@]} -eq 0 ]] || { echo "    expected 0 entries, got ${#ENTRIES_ID[@]}"; return 1; }
  cs_new_session
  sleep 0.05
  local np
  np=$(cs_read_state new_pane)
  [[ -n "${np}" ]] || { echo "    new_pane not set"; return 1; }
  local cp
  cp=$(cs_read_state current_pane)
  [[ -n "${cp}" ]] || { echo "    current_pane not set"; return 1; }
  cs_assert_consistent "fresh_no_sessions"
}

test_fresh_start_with_sessions() {
  cs_create_mock_session "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa" "first session"
  cs_create_mock_session "bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbbb" "second session"
  cs_scan_sessions
  [[ ${#ENTRIES_ID[@]} -eq 2 ]] || { echo "    expected 2 entries, got ${#ENTRIES_ID[@]}"; return 1; }
  cs_show_welcome
  sleep 0.05
  local wp
  wp=$(cs_read_state welcome_pane)
  [[ -n "${wp}" ]] || { echo "    welcome_pane not set"; return 1; }
  cs_assert_consistent "fresh_with_sessions"
}

test_select_dormant() {
  local sid="aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa"
  cs_create_mock_session "${sid}" "test dormant"
  cs_scan_sessions
  cs_show_welcome
  sleep 0.05

  local idx
  idx=$(find_entry_index "${sid}")
  [[ "${idx}" != "-1" ]] || { echo "    session not found in entries"; return 1; }
  SELECTED=${idx}
  cs_activate_selected
  sleep 0.05

  local cp
  cp=$(cs_read_state current_pane)
  [[ -n "${cp}" ]] || { echo "    current_pane not set after select"; return 1; }
  local wp
  wp=$(cs_read_state welcome_pane)
  [[ -z "${wp}" ]] || { echo "    welcome_pane not cleared"; return 1; }
  cs_assert_consistent "select_dormant"
}

test_switch_sessions() {
  local sid_a="aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa"
  local sid_b="bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbbb"
  cs_create_mock_session "${sid_a}" "session A"
  cs_create_mock_session "${sid_b}" "session B"

  # Resume A
  cs_resume_session "${sid_a}"
  sleep 0.05
  local pane_a
  pane_a=$(cs_read_state current_pane)

  # Resume B
  cs_resume_session "${sid_b}"
  sleep 0.05
  local pane_b
  pane_b=$(cs_read_state current_pane)

  # A should still be alive (parked)
  pane_alive "${pane_a}" || { echo "    pane A died after switch"; return 1; }
  # B should be current
  [[ "${pane_b}" != "${pane_a}" ]] || { echo "    pane B same as pane A"; return 1; }
  cs_assert_consistent "switch_sessions"
}

test_close_active() {
  local sid="aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa"
  cs_create_mock_session "${sid}" "to close"
  cs_scan_sessions

  local idx
  idx=$(find_entry_index "${sid}")
  SELECTED=${idx}
  cs_resume_session "${sid}"
  sleep 0.05

