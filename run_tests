test_discover_remote_servers() {
  # Create a second tmux server
  local remote_server="cs-fake-remote-$$"
  local remote_sanitized="-fake-remote-$$"
  local base="${XDG_RUNTIME_DIR:-/tmp}"
  local socket_dir="${TMUX_TMPDIR:-/tmp/tmux-$(id -u)}"
  local remote_state="${base}/claude-spaces/${remote_sanitized}"
  mkdir -p "${remote_state}"
  echo "/tmp/fake-remote-project" > "${remote_state}/project_path"
  mkdir -p "${base}/claude-spaces/.servers"
  ln -snf "${remote_state}" "${base}/claude-spaces/.servers/${remote_server}"
  mkdir -p "/tmp/fake-remote-project"
  command tmux -L "${remote_server}" new-session -d -s test "sleep 99999"
  sleep 0.05

  cs_discover_servers

  # Should find the remote server
  local found=0
  for entry in "${REMOTE_SERVERS[@]}"; do
    if [[ "${entry}" == "${remote_server}|/tmp/fake-remote-project" ]]; then
      found=1
      break
    fi
  done
  [[ ${found} -eq 1 ]] || { echo "    remote server not discovered"; command tmux -L "${remote_server}" kill-server 2>/dev/null; [[ -n "${socket_dir}" && -n "${remote_server}" ]] && rm -f "${socket_dir}/${remote_server}"; rm -rf "${remote_state}" "/tmp/fake-remote-project"; rm -f "${base}/claude-spaces/.servers/${remote_server}"; return 1; }

  # Should NOT include our own server
  for entry in "${REMOTE_SERVERS[@]}"; do
    local srv="${entry%%|*}"
    if [[ "${srv}" == "${TMUX_SERVER}" ]]; then
      echo "    own server found in remote list"
      command tmux -L "${remote_server}" kill-server 2>/dev/null
      [[ -n "${socket_dir}" && -n "${remote_server}" ]] && rm -f "${socket_dir}/${remote_server}"
      rm -rf "${remote_state}" "/tmp/fake-remote-project"
      rm -f "${base}/claude-spaces/.servers/${remote_server}"
      return 1
    fi
  done

  # Cleanup
  command tmux -L "${remote_server}" kill-server 2>/dev/null
  [[ -n "${socket_dir}" && -n "${remote_server}" ]] && rm -f "${socket_dir}/${remote_server}"
  rm -rf "${remote_state}" "/tmp/fake-remote-project"
  rm -f "${base}/claude-spaces/.servers/${remote_server}"
}

