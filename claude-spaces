    CACHED_ENTRIES_ID=(); CACHED_ENTRIES_NAME=(); CACHED_ENTRIES_MTIME=()
    CACHED_ENTRIES_STATUS=(); CACHED_ENTRIES_PANE=(); CACHED_ENTRIES_TYPE=()
