# ── Session Discovery ─────────────────────────────
cs_get_project_dir() {
    local sanitized
    sanitized=$(cs_sanitize_path "${PWD}")
    echo "${PROJECTS_DIR}/${sanitized}"
}

cs_clean_message() {
    local msg="$1"
    # First line only
    msg="${msg%%$'\n'*}"
    # Strip leading filler
    msg=$(echo "${msg}" | sed -E 's/^(I want to |Can you |Please |Hey |Hi |Could you |I need to |Help me |I would like to )//i')
    echo "${msg}"
}

cs_resolve_name() {
    local sid="$1" jsonl="$2"
    if [[ -n "${CUSTOM_NAMES[${sid}]:-}" ]]; then
        echo "${CUSTOM_NAMES[${sid}]}"
        return
    fi
    local name
    name=$(head -20 "${jsonl}" | jq -r '
        select(.type == "user" and (.message.content | type) == "string" and (((.message.content | startswith("<local-command-")) or (.message.content | startswith("<command-"))) | not))
        | .message.content
        | split("\n")[0]
    ' 2>/dev/null | head -1)
    if [[ -n "${name}" ]]; then
        name=$(cs_clean_message "${name}")
    fi
    if [[ -z "${name}" || ${#name} -lt 3 ]]; then
        name="${sid:0:8}"
    else
        cs_set_kv "${NAMES_FILE}" "${sid}" "${name}"
        CUSTOM_NAMES["${sid}"]="${name}"
    fi
    echo "${name}"
}

cs_check_new_pane() {
    local new_p
    new_p=$(cs_read_state new_pane)
    if [[ -n "${new_p}" ]]; then
        if ! cs_pane_alive "${new_p}"; then
            rm -f "${STATE_DIR}/new_pane" "${STATE_DIR}/panes/${new_p#%}"
            local cp
            cp=$(cs_read_state current_pane)
            if [[ "${cp}" == "${new_p}" ]]; then
                echo "" > "${STATE_DIR}/current_pane"
            fi
        else
            cs_entry_prepend "__new__" "(new session)" "$(date +%s)" "managed" "${new_p}" "local" ""
        fi
    fi
}

cs_scan_sessions() {
    cs_refresh_pane_cache
    local project_dir
    project_dir=$(cs_get_project_dir)

    cs_entry_clear
    cs_load_shared_maps

    if [[ ! -d "${project_dir}" ]]; then
        cs_check_new_pane
        return 0
    fi

    # Build active-elsewhere set: sessionId -> pid
    declare -A active_pids
    if [[ -d "${SESSIONS_DIR}" ]]; then
        for f in "${SESSIONS_DIR}"/*.json; do
            [[ -f "${f}" ]] || continue
            local content pid sid
            content=$(< "${f}") || continue
            [[ "${content}" =~ \"pid\":[[:space:]]*([0-9]+) ]] || continue
            pid="${BASH_REMATCH[1]}"
            [[ "${content}" =~ \"sessionId\":[[:space:]]*\"([^\"]+)\" ]] || continue
            sid="${BASH_REMATCH[1]}"
            kill -0 "${pid}" 2>/dev/null && active_pids["${sid}"]="${pid}"
        done
    fi

    # Resolve "new" panes to real session IDs
    for f in "${STATE_DIR}"/panes/*; do
        [[ -f "${f}" ]] || continue
        local content
        content=$(cat "${f}" 2>/dev/null)
        if [[ "${content}" == "new" ]]; then
            local pn
            pn="%${f##*/}"
            cs_pane_alive "${pn}" || continue
            local pp
            pp=$(_tmux display-message -t "${pn}" -p '#{pane_pid}' 2>/dev/null) || continue
            pp=$(_cs_find_session_pid "${pp}") || continue
            if [[ -f "${SESSIONS_DIR}/${pp}.json" ]]; then
                local rsid
                rsid=$(jq -r '.sessionId' "${SESSIONS_DIR}/${pp}.json" 2>/dev/null)
                local pdir
                pdir=$(cs_get_project_dir)
                if [[ -n "${rsid}" && -f "${pdir}/${rsid}.jsonl" ]]; then
                    echo "${rsid}" > "${f}"
                    rm -f "${STATE_DIR}/new_pane"
                fi
            fi
        fi
    done

    # Build managed pane set: sessionId -> pane_id
    declare -A managed_panes
    for f in "${STATE_DIR}"/panes/*; do
        [[ -f "${f}" ]] || continue
        local pane_num pane_id sid
        pane_num="${f##*/}"
        pane_id="%${pane_num}"
        sid=$(cat "${f}" 2>/dev/null) || continue
        if cs_pane_alive "${pane_id}"; then
            managed_panes["${sid}"]="${pane_id}"
        else
            rm -f "${f}"
        fi
    done

    # Scan JSONL files
    declare -A mtimes
    while read -r mt fn; do
        mtimes["${fn}"]="${mt}"
    done < <(_cs_stat "${project_dir}"/*.jsonl 2>/dev/null)
    for f in "${project_dir}"/*.jsonl; do
        [[ -f "${f}" ]] || continue
        local sid="${f##*/}"
        sid="${sid%.jsonl}"
        [[ "${sid}" =~ ${UUID_RE} ]] || continue
        [[ -v "HIDDEN_SET[${sid}]" ]] && ((! SHOW_HIDDEN)) && continue

        local mtime="${mtimes[${f}]}"

        local name
        name=$(cs_resolve_name "${sid}" "${f}")
        [[ -v "HIDDEN_SET[${sid}]" ]] && name="[h] ${name}"

        # Status
        local status="dormant"
        local pane=""
        if [[ -v "managed_panes[${sid}]" ]]; then
            status="managed"
            pane="${managed_panes[${sid}]}"
        elif [[ -v "active_pids[${sid}]" ]]; then
            status="active_elsewhere"
        fi

        cs_entry_append "${sid}" "${name}" "${mtime}" "${status}" "${pane}" "local" ""
    done

    cs_sort_entries

    cs_check_new_pane
}

cs_sort_entries() {
    local n=${#ENTRIES_ID[@]}
    ((n <= 1)) && return 0

    local now
    now=$(date +%s)
    local cutoff=$((now - RECENT_THRESHOLD * 60))
    RECENT_CUTOFF=${cutoff}

    # Partition: recent by name, older by mtime desc; hidden always older
    local recent_indices=() older_indices=()
    for ((i = 0; i < n; i++)); do
        if [[ -v "HIDDEN_SET[${ENTRIES_ID[i]}]" ]]; then
            older_indices+=("${i}")
        elif ((ENTRIES_MTIME[i] >= cutoff)); then
            recent_indices+=("${i}")
        else
            older_indices+=("${i}")
        fi
    done

    # Sort recent by name (case-insensitive), index first to handle spaces
    local sorted_recent=""
    if ((${#recent_indices[@]} > 0)); then
        sorted_recent=$(
            for i in "${recent_indices[@]}"; do
                echo "${i} ${ENTRIES_NAME[${i}],,}"
            done | sort -t' ' -k2
        )
    fi

    # Sort older by mtime descending
    local sorted_older=""
    if ((${#older_indices[@]} > 0)); then
        sorted_older=$(
            for i in "${older_indices[@]}"; do
                echo "${ENTRIES_MTIME[${i}]} ${i}"
            done | sort -rnk1
        )
    fi

    local new_id=() new_name=() new_mtime=() new_status=() new_pane=() new_type=() new_path=()
    local idx
    if [[ -n "${sorted_recent}" ]]; then
        while read -r idx _; do
            new_id+=("${ENTRIES_ID[${idx}]}")
            new_name+=("${ENTRIES_NAME[${idx}]}")
            new_mtime+=("${ENTRIES_MTIME[${idx}]}")
            new_status+=("${ENTRIES_STATUS[${idx}]}")
            new_pane+=("${ENTRIES_PANE[${idx}]}")
            new_type+=("${ENTRIES_TYPE[${idx}]}")
            new_path+=("${ENTRIES_PATH[${idx}]}")
        done <<< "${sorted_recent}"
    fi
    if [[ -n "${sorted_older}" ]]; then
        while read -r _ idx; do
            new_id+=("${ENTRIES_ID[${idx}]}")
            new_name+=("${ENTRIES_NAME[${idx}]}")
            new_mtime+=("${ENTRIES_MTIME[${idx}]}")
            new_status+=("${ENTRIES_STATUS[${idx}]}")
            new_pane+=("${ENTRIES_PANE[${idx}]}")
            new_type+=("${ENTRIES_TYPE[${idx}]}")
            new_path+=("${ENTRIES_PATH[${idx}]}")
        done <<< "${sorted_older}"
    fi

    ENTRIES_ID=("${new_id[@]}")
    ENTRIES_NAME=("${new_name[@]}")
    ENTRIES_MTIME=("${new_mtime[@]}")
    ENTRIES_STATUS=("${new_status[@]}")
    ENTRIES_PANE=("${new_pane[@]}")
    ENTRIES_TYPE=("${new_type[@]}")
    ENTRIES_PATH=("${new_path[@]}")
}

cs_rescan() {
    local selected_id=""
    if ((${#ENTRIES_ID[@]} > 0 && SELECTED < ${#ENTRIES_ID[@]})); then
        selected_id="${ENTRIES_ID[${SELECTED}]}"
    fi
    cs_build_all_entries
    cs_search_save_full
    # Restore selection: by ID, then by pane, then clamp
    local _sel_found=0
    if [[ -n "${selected_id}" ]]; then
        local idx
        idx=$(cs_find_entry_index "${selected_id}")
        if [[ "${idx}" != "-1" ]]; then
            SELECTED=${idx}
            _sel_found=1
        fi
    fi
    if ((!_sel_found)); then
        local cur_pane
        cur_pane=$(cs_read_state current_pane)
        if [[ -n "${cur_pane}" ]]; then
            local pidx
            pidx=$(cs_find_entry_by_pane "${cur_pane}")
            if [[ "${pidx}" != "-1" ]]; then
                SELECTED=${pidx}
            fi
        fi
        local n=${#ENTRIES_ID[@]}
        if ((SELECTED >= n && n > 0)); then
            SELECTED=$((n - 1))
        fi
    fi
    if ((SEARCH_ACTIVE)); then
        cs_search_apply_filter
    fi
}

cs_find_entry_index() {
    local target_id="$1"
    for ((fi=0; fi < ${#ENTRIES_ID[@]}; fi++)); do
        if [[ "${ENTRIES_ID[${fi}]}" == "${target_id}" ]]; then
            echo "${fi}"
            return
        fi
    done
    echo "-1"
}

cs_find_entry_by_pane() {
    local target_pane="$1"
    for ((fi=0; fi < ${#ENTRIES_PANE[@]}; fi++)); do
        if [[ "${ENTRIES_PANE[${fi}]}" == "${target_pane}" ]]; then
            echo "${fi}"
            return
        fi
    done
    echo "-1"
}

# ── Cross-server Discovery ────────────────────────
REMOTE_SERVERS=()
INACTIVE_PROJECTS=()
cs_cache_clear
LAST_REMOTE_SCAN=0
LAST_PATH_SET=""

# ── Command Menu ─────────────────────────────────
MENU_ACTIVE=0
MENU_TARGET_ID=""
SHOW_HIDDEN=0
MENU_KEYS=()
