# ── Preflight ─────────────────────────────────────
cs_preflight() {
    local ok=1
    command -v tmux &>/dev/null || { echo "ERROR: tmux not found. Please install using your package manager."; ok=0; }
    command -v jq &>/dev/null || { echo "ERROR: jq not found. Please install using your package manager."; ok=0; }
    command -v claude &>/dev/null || { echo "ERROR: claude not found. Install from https://docs.anthropic.com/en/docs/claude-code"; ok=0; }
    ((ok)) || exit 1
}

# ── Portability ───────────────────────────────────
if stat -c '%Y' / &>/dev/null; then
  _cs_stat() { stat -c '%Y %n' "$@"; }
else
  _cs_stat() { stat -f '%m %N' "$@"; }
fi

# ── State ─────────────────────────────────────────
cs_sanitize_path() {
    local p="${1//\//-}"
    echo "${p//_/-}"
}
PWD_SANITIZED=$(cs_sanitize_path "${PWD}")

cs_init_state() {
    PWD_SANITIZED=$(cs_sanitize_path "${PWD}")
    local sanitized="${PWD_SANITIZED}"
    local base="${XDG_RUNTIME_DIR:-/tmp}"
    STATE_DIR="${base}/claude-spaces/${sanitized}"
    # If picker pane from previous run is dead, wipe stale state
    cs_refresh_pane_cache
    local old_picker
    old_picker=$(cs_read_state picker_pane)
    if [[ -n "${old_picker}" ]] && ! cs_pane_alive "${old_picker}"; then
        rm -rf "${STATE_DIR}"
    fi
    mkdir -p "${STATE_DIR}/panes" "${STATE_DIR}/term"
    echo "${PWD}" > "${STATE_DIR}/project_path"
    # Server → state dir mapping for cross-server discovery
    mkdir -p "${base}/claude-spaces/.servers"
    ln -snf "${STATE_DIR}" "${base}/claude-spaces/.servers/${TMUX_SERVER}"
}

cs_read_state() { cat "${STATE_DIR}/$1" 2>/dev/null || true; }

_cs_find_session_pid() {
  local pid="$1"
  [[ -f "${SESSIONS_DIR}/${pid}.json" ]] && { echo "${pid}"; return 0; }
  local child
  for child in $(pgrep -P "${pid}" 2>/dev/null); do
    _cs_find_session_pid "${child}" && return 0
  done
  return 1
}

cs_rename_pane_window() {
    local pane="$1" name="$2"
    if ((${#name} > WINDOW_NAME_LEN)); then
        name="${name:0:${WINDOW_NAME_LEN}}"
    fi
    _tmux rename-window -t "${pane}" "${name}" 2>/dev/null || true
    _tmux set-option -t "${pane}" -w automatic-rename off 2>/dev/null || true
}

LIVE_PANES=""
cs_refresh_pane_cache() {
    LIVE_PANES=$(_tmux list-panes -a -F '#{pane_id}' 2>/dev/null || true)
}
cs_pane_alive() {
    [[ $'\n'"${LIVE_PANES}"$'\n' == *$'\n'"$1"$'\n'* ]]
}

# ── Entry Helpers ─────────────────────────────────
cs_entry_append() {
    if [[ -n "${CS_TESTING:-}" ]] && (($# != 7)); then
        echo "FATAL: cs_entry_append called with $# args, expected 7" >&2; exit 1
    fi
    ENTRIES_ID+=("$1"); ENTRIES_NAME+=("$2"); ENTRIES_MTIME+=("$3")
    ENTRIES_STATUS+=("$4"); ENTRIES_PANE+=("$5"); ENTRIES_TYPE+=("$6"); ENTRIES_PATH+=("$7")
}

cs_entry_prepend() {
    if [[ -n "${CS_TESTING:-}" ]] && (($# != 7)); then
        echo "FATAL: cs_entry_prepend called with $# args, expected 7" >&2; exit 1
    fi
    ENTRIES_ID=("$1" "${ENTRIES_ID[@]}"); ENTRIES_NAME=("$2" "${ENTRIES_NAME[@]}")
    ENTRIES_MTIME=("$3" "${ENTRIES_MTIME[@]}"); ENTRIES_STATUS=("$4" "${ENTRIES_STATUS[@]}")
    ENTRIES_PANE=("$5" "${ENTRIES_PANE[@]}"); ENTRIES_TYPE=("$6" "${ENTRIES_TYPE[@]}")
    ENTRIES_PATH=("$7" "${ENTRIES_PATH[@]}")
}

cs_entry_clear() {
    ENTRIES_ID=(); ENTRIES_NAME=(); ENTRIES_MTIME=(); ENTRIES_STATUS=()
    ENTRIES_PANE=(); ENTRIES_TYPE=(); ENTRIES_PATH=()
}

declare -gA HIDDEN_SET
declare -gA CUSTOM_NAMES
declare -gA PROJECT_NAMES

cs_load_shared_maps() {
    HIDDEN_SET=()
    if [[ -f "${HIDDEN_FILE}" ]]; then
        while IFS= read -r hid; do
            [[ -n "${hid}" ]] && HIDDEN_SET["${hid}"]=1
        done < "${HIDDEN_FILE}"
    fi
    CUSTOM_NAMES=()
    if [[ -f "${NAMES_FILE}" ]]; then
        while IFS='=' read -r nkey nval; do
            [[ -z "${nkey}" || "${nkey}" =~ ^[[:space:]]*# ]] && continue
            CUSTOM_NAMES["${nkey}"]="${nval}"
        done < "${NAMES_FILE}"
    fi
    PROJECT_NAMES=()
    if [[ -f "${PROJECT_NAMES_FILE}" ]]; then
        while IFS='=' read -r nkey nval; do
            [[ -z "${nkey}" || "${nkey}" =~ ^[[:space:]]*# ]] && continue
            PROJECT_NAMES["${nkey}"]="${nval}"
        done < "${PROJECT_NAMES_FILE}"
    fi
}

# ── Display Name Disambiguation ──────────────────
declare -gA DISPLAY_NAMES

cs_compress_suffix() {
    local suffix="$1"
    local stripped="${suffix//[!\/]/}"
    local slashes=${#stripped}
    if ((slashes <= 1)); then
        echo "${suffix}"
    else
        echo "${suffix%%/*}/.../${suffix##*/}"
    fi
}

cs_resolve_collision_group() {
    local -n _grp=$1
    local n=${#_grp[@]}
    local -a comp_strs=()
    local gi
    for ((gi=0; gi<n; gi++)); do
        local -a _parts
        IFS='/' read -ra _parts <<< "${_grp[gi]}"
        local -a _filtered=()
        local _c
        for _c in "${_parts[@]}"; do
            [[ -n "${_c}" ]] && _filtered+=("${_c}")
        done
        local IFS=$'\n'
        comp_strs+=("${_filtered[*]}")
    done
    local depth=1
    while true; do
        local -A suffix_map
        suffix_map=()
        local -a suffixes=()
        for ((gi=0; gi<n; gi++)); do
            local -a comps
            mapfile -t comps <<< "${comp_strs[gi]}"
            local nc=${#comps[@]}
            local suffix=""
            local di start=$((nc - depth))
            ((start < 0)) && start=0
            for ((di=start; di<nc; di++)); do
                [[ -n "${suffix}" ]] && suffix+="/"
                suffix+="${comps[di]}"
            done
            suffixes+=("${suffix}")
            suffix_map["${suffix}"]=$(( ${suffix_map["${suffix}"]:-0} + 1 ))
        done
        local all_unique=1
        for ((gi=0; gi<n; gi++)); do
            ((suffix_map["${suffixes[gi]}"] > 1)) && { all_unique=0; break; }
        done
        if ((all_unique)); then
            # Compress, then check for display collisions
            local -a compressed=()
            local -A comp_count
            comp_count=()
            for ((gi=0; gi<n; gi++)); do
                local _cs
                _cs=$(cs_compress_suffix "${suffixes[gi]}")
                compressed+=("${_cs}")
                comp_count["${_cs}"]=$(( ${comp_count["${_cs}"]:-0} + 1 ))
            done
            for ((gi=0; gi<n; gi++)); do
                if ((comp_count["${compressed[gi]}"] > 1)); then
                    DISPLAY_NAMES["${_grp[gi]}"]="${suffixes[gi]}"
                else
                    DISPLAY_NAMES["${_grp[gi]}"]="${compressed[gi]}"
                fi
            done
            return
        fi
        ((depth++))
        if ((depth > 50)); then
            for ((gi=0; gi<n; gi++)); do
                DISPLAY_NAMES["${_grp[gi]}"]="${_grp[gi]}"
            done
            return
        fi
    done
}

cs_compute_display_names() {
    DISPLAY_NAMES=()
    local -a all_paths=()
    local -A seen
    local _p
    for _p in "${PWD}" \
              "${REMOTE_SERVERS[@]/#*|/}" \
              "${INACTIVE_PROJECTS[@]/#*|/}"; do
        [[ -z "${_p}" || -v "seen[${_p}]" ]] && continue
        seen["${_p}"]=1
        all_paths+=("${_p}")
    done
    local -A leaf_count
    for _p in "${all_paths[@]}"; do
        local _leaf="${_p##*/}"
        leaf_count["${_leaf}"]=$(( ${leaf_count["${_leaf}"]:-0} + 1 ))
    done
    local -A leaf_done
    for _p in "${all_paths[@]}"; do
        local _leaf="${_p##*/}"
        if ((leaf_count["${_leaf}"] == 1)); then
            DISPLAY_NAMES["${_p}"]="${_leaf}"
        elif [[ ! -v "leaf_done[${_leaf}]" ]]; then
            leaf_done["${_leaf}"]=1
            local -a group=()
            local _q
            for _q in "${all_paths[@]}"; do
                [[ "${_q##*/}" == "${_leaf}" ]] && group+=("${_q}")
            done
            cs_resolve_collision_group group
        fi
    done
}

