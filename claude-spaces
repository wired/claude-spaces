# Re-exec under bash 4.3+ on macOS if needed (namerefs require 4.3)
if ((BASH_VERSINFO[0] < 4 || (BASH_VERSINFO[0] == 4 && BASH_VERSINFO[1] < 3))); then
  for _bash in /opt/homebrew/bin/bash /usr/local/bin/bash; do
    [[ -x "$_bash" ]] && exec "$_bash" "$0" "$@"
  done
  echo "ERROR: bash 4.3+ required (found ${BASH_VERSION}). On macOS: brew install bash and add Homebrew's bin to your PATH before /bin"
  exit 1
fi

VERSION="0.9.4"
_cs_realpath() {
  local p="$1"
  local dir
  while [[ -L "$p" ]]; do
    dir="$(cd "$(dirname "$p")" && pwd)"
    p="$(readlink "$p")"
    [[ "$p" != /* ]] && p="$dir/$p"
  done
  echo "$(cd "$(dirname "$p")" && pwd)/$(basename "$p")"
}
SCRIPT_PATH="$(_cs_realpath "$0")"
CLAUDE_DIR="${HOME}/.claude"
PROJECTS_DIR="${CLAUDE_DIR}/projects"
SESSIONS_DIR="${CLAUDE_DIR}/sessions"
CS_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/claude-spaces"
CS_DATA_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/claude-spaces"
CONFIG_FILE="${CS_CONFIG_DIR}/config"
NAMES_FILE="${CS_DATA_DIR}/names"
HIDDEN_FILE="${CS_DATA_DIR}/hidden"
PROJECT_NAMES_FILE="${CS_DATA_DIR}/project_names"

# ── Defaults ──────────────────────────────────────
PICKER_WIDTH="30"
RECENT_THRESHOLD=10
# shellcheck disable=SC2034
GROUP_BY="project"
PICKER_SIDE="right"
WINDOW_NAME_LEN=12
cs_server_name() {
  local sum tail
  sum=$(printf '%s' "$1" | cksum | cut -d' ' -f1)
  tail="${1: -30}"
  tail="${tail//\//-}"
  printf 'cs-%s-%s' "$tail" "$sum"
}
TMUX_SERVER=$(cs_server_name "$PWD")
TMUX_CONF="${HOME}/.tmux.conf"
TERMINAL_HEIGHT="35%"
SHOW_INDEX=1
CS_PREFIX=""
declare -gA BIND_OVERRIDES=()
