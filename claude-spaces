CS_CLR_HEADER_BG='\e[7m'
CS_CLR_ACTIVE='\e[1;32m'
CS_CLR_BELL='\e[31m'
CS_CLR_RUNNING=''
CS_CLR_DORMANT='\e[2m'
CS_CLR_LOCKED='\e[9;2m'
CS_CLR_SELECTION='\e[48;5;237m'
CS_CLR_CHROME='\e[2m'
CS_CLR_SECTION='\e[2;1m'
CS_CLR_PROMPT_WARN='\e[33m'
CS_CLR_PROMPT_DANGER='\e[31;1m'
CS_CLR_BELL_MENU='\e[1;33m'
CS_CLR_SEARCH_ACTIVE='\e[7m\e[1m'
CS_CLR_SEARCH_BAR='\e[30;42m'
CS_CLR_BOLD='\e[1m'
UUID_RE='^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$'

# ── tmux wrapper ─────────────────────────────────
_tmux() {
    if [[ -n "${TMUX_SERVER}" ]]; then
        command tmux -L "${TMUX_SERVER}" "$@"
    else
        command tmux "$@"
    fi
}

cs_exec_tmux() {
    if [[ -n "${TMUX_SERVER}" ]]; then
        exec tmux -L "${TMUX_SERVER}" "$@"
    else
        exec tmux "$@"
    fi
}

# ── Config ────────────────────────────────────────
cs_load_config() {
    mkdir -p "${CS_CONFIG_DIR}" "${CS_DATA_DIR}"
    if [[ ! -f "${CONFIG_FILE}" ]]; then
        cs_create_default_config
    fi
    while IFS='=' read -r key value; do
        [[ -z "${key}" || "${key}" =~ ^[[:space:]]*# ]] && continue
        key="${key// /}"
        value="${value// /}"
        # shellcheck disable=SC2034
        case "${key}" in
            picker_width) PICKER_WIDTH="${value}" ;;
            recent_threshold) RECENT_THRESHOLD="${value}" ;;
            group_by) GROUP_BY="${value}" ;;
            picker_side) PICKER_SIDE="${value}" ;;

            window_name_len) WINDOW_NAME_LEN="${value}" ;;
            tmux_conf) TMUX_CONF="${value}" ;;
            terminal_height) TERMINAL_HEIGHT="${value}" ;;
            show_index) SHOW_INDEX="${value}" ;;
            prefix) CS_PREFIX="${value}" ;;
            color_header_bg) CS_CLR_HEADER_BG="${value}" ;;
            color_active) CS_CLR_ACTIVE="${value}" ;;
            color_bell) CS_CLR_BELL="${value}" ;;
            color_running) CS_CLR_RUNNING="${value}" ;;
            color_dormant) CS_CLR_DORMANT="${value}" ;;
            color_locked) CS_CLR_LOCKED="${value}" ;;
            color_selection) CS_CLR_SELECTION="${value}" ;;
            color_chrome) CS_CLR_CHROME="${value}" ;;
            color_section) CS_CLR_SECTION="${value}" ;;
            color_prompt_warn) CS_CLR_PROMPT_WARN="${value}" ;;
            color_prompt_danger) CS_CLR_PROMPT_DANGER="${value}" ;;
            color_bell_menu) CS_CLR_BELL_MENU="${value}" ;;
            color_search_active) CS_CLR_SEARCH_ACTIVE="${value}" ;;
            color_search_bar) CS_CLR_SEARCH_BAR="${value}" ;;
            color_bold) CS_CLR_BOLD="${value}" ;;
            bind_*) BIND_OVERRIDES["${key}"]="${value}" ;;
        esac
    done < "${CONFIG_FILE}"
}

